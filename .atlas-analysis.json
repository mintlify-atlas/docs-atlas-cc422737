  "keyFeatures": [
    "Rich spreadsheet interface with grid, gallery, form, kanban, and calendar views",
    "Connect to existing databases (PostgreSQL, MySQL, SQLite) or use built-in storage",
    "REST APIs with auto-generated Swagger documentation",
    "Webhooks and automation with integrations for Slack, Discord, email services",
    "Fine-grained access control with role-based permissions",
    "Real-time collaboration with comments and notifications",
    "Formula fields with Excel-like functions",
    "Link to other records with lookup and rollup fields",
    "File attachments with cloud storage integration (S3, Minio, GCS)",
    "Public and password-protected view sharing",
    "Self-hostable with Docker and Kubernetes deployment options"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/user/signup - User signup",
    "POST /api/v1/auth/user/signin - User signin",
    "POST /api/v1/auth/token/create - Create API token",
    "GET /api/v1/db/meta/projects - List bases",
    "POST /api/v1/db/meta/projects/{baseId}/tables - Create table",
    "GET /api/v1/db/data/{baseId}/{tableName} - List records",
    "POST /api/v1/db/data/{baseId}/{tableName} - Create record",
    "GET /api/v1/db/data/{baseId}/{tableName}/{rowId} - Get record",
    "PATCH /api/v1/db/data/{baseId}/{tableName}/{rowId} - Update record",
    "DELETE /api/v1/db/data/{baseId}/{tableName}/{rowId} - Delete record",
    "GET /api/v1/db/meta/tables/{tableId}/columns - List columns",
    "POST /api/v1/db/meta/tables/{tableId}/columns - Create column",
    "GET /api/v1/db/meta/tables/{tableId}/views - List views",
    "POST /api/v1/db/meta/tables/{tableId}/views - Create view",
    "GET /api/v1/db/meta/tables/{tableId}/hooks - List webhooks",
    "POST /api/v1/db/meta/tables/{tableId}/hooks - Create webhook"
  ]
}
